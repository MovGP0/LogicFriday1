<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="LogicFriday1.Views.AboutDialog"
        Title="About Logic Friday"
        Width="420"
        Height="240"
        MinWidth="420"
        MinHeight="240"
        MaxWidth="420"
        MaxHeight="240"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <Grid RowDefinitions="*,Auto"
          Margin="20">
        <StackPanel Spacing="8">
            <TextBlock Text="Logic Friday v. 1.1.4" />
            <TextBlock Text="logicfriday.exe" />
            <TextBlock Text="Copyright (C) 2006-2012" />
        </StackPanel>

        <Button Grid.Row="1"
                HorizontalAlignment="Center"
                MinWidth="80"
                IsDefault="True"
                IsCancel="True"
                Click="OkButton_OnClick">
            OK
        </Button>
    </Grid>

</Window>
