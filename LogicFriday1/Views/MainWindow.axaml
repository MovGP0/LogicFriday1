<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:LogicFriday1.Controls"
        xmlns:icons="using:LogicFriday1.MaterialIcons"
        xmlns:models="using:LogicFriday1.Models"
        xmlns:vm="using:LogicFriday1.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="720"
        x:Class="LogicFriday1.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="LogicFriday1"
        Width="1100"
        Height="720"
        MinWidth="900"
        MinHeight="560">

    <Window.Styles>
        <Style Selector="Button.toolbarButton">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="5" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.toolbarButton icons|PackIcon">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Foreground" Value="{DynamicResource LogicFriday.Brush.OnSurface}" />
        </Style>
        <Style Selector="Button.toolbarButton:pointerover icons|PackIcon">
            <Setter Property="Foreground" Value="{DynamicResource LogicFriday.Brush.OnSecondaryContainer}" />
        </Style>
        <Style Selector="Button.gatePaletteButton">
            <Setter Property="Width" Value="80" />
            <Setter Property="Height" Value="60" />
            <Setter Property="MinWidth" Value="80" />
            <Setter Property="MinHeight" Value="60" />
            <Setter Property="Padding" Value="3" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>
        <Style Selector="Button.gatePaletteButton icons|PackIcon">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Foreground" Value="{DynamicResource LogicFriday.Brush.OnSurface}" />
        </Style>
        <Style Selector="Button.gatePaletteButton:pointerover icons|PackIcon">
            <Setter Property="Foreground" Value="{DynamicResource LogicFriday.Brush.OnSecondaryContainer}" />
        </Style>
    </Window.Styles>

    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type models:GatePaletteItem}" x:DataType="models:GatePaletteItem">
            <Grid RowDefinitions="*,Auto">
                <controls:GatePaletteGlyph Grid.Row="0"
                                           Item="{Binding}" />
                <TextBlock Grid.Row="1"
                           Text="{Binding Label}"
                           FontSize="10"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource LogicFriday.Brush.OnSurfaceVariant}" />
            </Grid>
        </DataTemplate>
    </Window.DataTemplates>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New">
                    <MenuItem Header="Truth _Table"
                              Click="NewTruthTable_OnClick" />
                    <MenuItem Header="Logic _Equation"
                              Click="NewLogicEquation_OnClick" />
                    <MenuItem Header="Gate _Diagram"
                              Click="NewGateDiagram_OnClick" />
                </MenuItem>
                <MenuItem Header="_Open..." />
                <MenuItem Header="_Close"
                          Click="CloseDocument_OnClick" />
                <Separator />
                <MenuItem Header="Save _As..." />
                <Separator />
                <MenuItem Header="_Import Truth Table..."
                          Click="ImportTruthTable_OnClick" />
                <MenuItem Header="Export _Truth Table..." />
                <MenuItem Header="Export _Gate Diagram..." />
                <Separator />
                <MenuItem Header="_Print..." />
                <Separator />
                <MenuItem Header="E_xit"
                          Click="Exit_OnClick" />
            </MenuItem>

            <MenuItem Header="_Operation">
                <MenuItem Header="_Minimize..." />
                <MenuItem Header="Map to _Gates..." />
                <MenuItem Header="Generate C _Lookup Function..." />
                <Separator />
                <MenuItem Header="Clo_ne Function" />
                <Separator />
                <MenuItem Header="Compa_re Functions" />
                <MenuItem Header="_OR Functions" />
                <MenuItem Header="_AND Functions" />
                <MenuItem Header="_XOR Functions" />
                <Separator />
                <MenuItem Header="_Cancel Esc" />
            </MenuItem>

            <MenuItem Header="T_ruthtable">
                <MenuItem Header="_Modify Truth Table" />
                <Separator />
                <MenuItem Header="Show Tr_ue and Don't Care" />
                <MenuItem Header="Show All _Rows" />
                <Separator />
                <MenuItem Header="Select _All" />
                <Separator />
                <MenuItem Header="_True" />
                <MenuItem Header="_False" />
                <MenuItem Header="_Don't Care" />
                <MenuItem Header="_Invert" />
                <Separator />
                <MenuItem Header="_Submit (Enter)"
                          Click="TruthTableSubmit_OnClick" />
                <MenuItem Header="_Cancel (Esc)"
                          Click="TruthTableCancel_OnClick" />
            </MenuItem>

            <MenuItem Header="_Equation">
                <MenuItem Header="_Modify Equation" />
                <Separator />
                <MenuItem Header="Sum of Produc_ts" />
                <MenuItem Header="Pro_duct of Sums" />
                <MenuItem Header="_Factor" />
                <Separator />
                <MenuItem Header="_Undo (Ctrl+Z)" />
                <MenuItem Header="_Redo (Ctrl+Y)" />
                <Separator />
                <MenuItem Header="Cu_t (Ctrl+X)" />
                <MenuItem Header="_Copy (Ctrl+C)" />
                <MenuItem Header="_Paste (Ctrl+V)" />
                <MenuItem Header="_Delete (Del)" />
                <MenuItem Header="Select _All (Ctrl+A)" />
                <Separator />
                <MenuItem Header="_Submit (Enter)" />
                <MenuItem Header="_Cancel (Esc)" />
            </MenuItem>

            <MenuItem Header="_Gates">
                <MenuItem Header="_Modify Gate Diagram" />
                <Separator />
                <MenuItem Header="_Copy to Clipboard" />
                <MenuItem Header="IC _Package Info..." />
                <MenuItem Header="_Trace Gate Logic" />
                <Separator />
                <MenuItem Header="_Auto Redraw Diagram" />
                <Separator />
                <MenuItem Header="Zoom _In" />
                <MenuItem Header="Zoom _Out" />
                <MenuItem Header="_Zoom All" />
                <Separator />
                <MenuItem Header="_Delete Selected" />
                <Separator />
                <MenuItem Header="_Submit (Enter)" />
                <MenuItem Header="_Cancel (Esc)" />
            </MenuItem>

            <MenuItem Header="_View">
                <MenuItem Header="_Unminimized"
                          ToggleType="Radio"
                          GroupName="FunctionViewMode"
                          IsChecked="{Binding IsUnminimizedViewSelected}" />
                <MenuItem Header="_Minimized"
                          ToggleType="Radio"
                          GroupName="FunctionViewMode"
                          IsChecked="{Binding IsMinimizedViewSelected}"
                          Click="MinimizedView_OnClick" />
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="_Help Contents"
                          Click="HelpContents_OnClick" />
                <Separator />
                <MenuItem Header="_About Logic Friday..."
                          Click="AboutLogicFriday_OnClick" />
            </MenuItem>
        </Menu>

        <Border DockPanel.Dock="Top"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                Background="{DynamicResource LogicFriday.Brush.SurfaceContainerLow}"
                Padding="4,2">
            <StackPanel Orientation="Horizontal"
                        Spacing="2">
                <Button Classes="toolbarButton"
                        ToolTip.Tip="New...">
                    <icons:PackIcon Kind="FilePlus" />
                </Button>
                <Button Classes="toolbarButton"
                        ToolTip.Tip="Open...">
                    <icons:PackIcon Kind="FolderOpen" />
                </Button>
                <Button Classes="toolbarButton"
                        ToolTip.Tip="Save">
                    <icons:PackIcon Kind="ContentSave" />
                </Button>
                <Button Classes="toolbarButton"
                        ToolTip.Tip="Print">
                    <icons:PackIcon Kind="Printer" />
                </Button>

                <Border Width="1"
                        Height="22"
                        Margin="4,3"
                        Background="{DynamicResource SystemControlForegroundBaseLowBrush}" />

                <Button Classes="toolbarButton"
                        ToolTip.Tip="Cut">
                    <icons:PackIcon Kind="ContentCut" />
                </Button>
                <Button Classes="toolbarButton"
                        ToolTip.Tip="Copy">
                    <icons:PackIcon Kind="ContentCopy" />
                </Button>
                <Button Classes="toolbarButton"
                        ToolTip.Tip="Paste">
                    <icons:PackIcon Kind="ContentPaste" />
                </Button>
                <Button Classes="toolbarButton"
                        ToolTip.Tip="Undo">
                    <icons:PackIcon Kind="Undo" />
                </Button>
                <Button Classes="toolbarButton"
                        ToolTip.Tip="Redo">
                    <icons:PackIcon Kind="Redo" />
                </Button>

                <Border Width="1"
                        Height="22"
                        Margin="4,3"
                        Background="{DynamicResource SystemControlForegroundBaseLowBrush}" />

                <Button Classes="toolbarButton"
                        ToolTip.Tip="Minimize...">
                    <icons:PackIcon Kind="ChartBellCurve" />
                </Button>
                <Button Classes="toolbarButton"
                        ToolTip.Tip="Map to Gates...">
                    <icons:PackIcon Kind="MapMarkerPath" />
                </Button>
                <Button Classes="toolbarButton"
                        ToolTip.Tip="Zoom In">
                    <icons:PackIcon Kind="MagnifyPlus" />
                </Button>
                <Button Classes="toolbarButton"
                        ToolTip.Tip="Zoom Out">
                    <icons:PackIcon Kind="MagnifyMinus" />
                </Button>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                Background="{DynamicResource LogicFriday.Brush.SurfaceContainerLow}"
                Padding="8,4">
            <TextBlock Text="{Binding StatusText}" />
        </Border>

        <Border Padding="8"
                Background="{DynamicResource LogicFriday.Brush.Surface}">
            <Grid RowDefinitions="160,Auto,*">
                <DataGrid x:Name="FunctionSummaryDataGrid"
                          ItemsSource="{Binding FunctionSummaries}"
                          SelectedItem="{Binding SelectedFunctionSummary, Mode=TwoWay}"
                          SelectionChanged="FunctionSummaryDataGrid_OnSelectionChanged"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserResizeColumns="True"
                          CanUserReorderColumns="True"
                          CanUserSortColumns="True"
                          GridLinesVisibility="All"
                          HeadersVisibility="Column"
                          Background="{DynamicResource LogicFriday.Brush.SurfaceContainerLowest}"
                          Foreground="{DynamicResource LogicFriday.Brush.OnSurface}"
                          BorderBrush="{DynamicResource LogicFriday.Brush.OutlineVariant}"
                          Margin="0,0,0,8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Function"
                                            Binding="{Binding Function}"
                                            Width="*" />
                        <DataGridTextColumn Header="Inputs"
                                            Binding="{Binding Inputs}" />
                        <DataGridTextColumn Header="Outputs"
                                            Binding="{Binding Outputs}" />
                        <DataGridTextColumn Header="True"
                                            Binding="{Binding True}" />
                        <DataGridTextColumn Header="False"
                                            Binding="{Binding False}" />
                        <DataGridTextColumn Header="DC"
                                            Binding="{Binding DC}" />
                        <DataGridTextColumn Header="PI"
                                            Binding="{Binding PI}" />
                        <DataGridTextColumn Header="Gates"
                                            Binding="{Binding Gates}" />
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Grid.Row="1"
                           IsVisible="{Binding IsEquationEditorVisible}"
                           Text="Logic Equation"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />
                <TextBox x:Name="EquationEditor"
                         Grid.Row="2"
                         IsVisible="{Binding IsEquationEditorVisible}"
                         Text="{Binding LogicEquationText, Mode=TwoWay}"
                         AcceptsReturn="True"
                         FontFamily="Courier New"
                         TextWrapping="NoWrap"
                         PlaceholderText="Enter a logic equation...">
                    <TextBox.ContextMenu>
                        <ContextMenu Opening="EquationEditorContextMenu_OnOpening">
                            <MenuItem x:Name="EquationEditorUndoMenuItem"
                                      Header="Undo"
                                      Click="EquationEditorUndo_OnClick" />
                            <MenuItem x:Name="EquationEditorRedoMenuItem"
                                      Header="Redo"
                                      Click="EquationEditorRedo_OnClick" />
                            <Separator />
                            <MenuItem x:Name="EquationEditorCutMenuItem"
                                      Header="Cut"
                                      Click="EquationEditorCut_OnClick" />
                            <MenuItem x:Name="EquationEditorCopyMenuItem"
                                      Header="Copy"
                                      Click="EquationEditorCopy_OnClick" />
                            <MenuItem Header="Paste"
                                      Click="EquationEditorPaste_OnClick" />
                            <MenuItem x:Name="EquationEditorDeleteMenuItem"
                                      Header="Delete"
                                      Click="EquationEditorDelete_OnClick" />
                            <MenuItem x:Name="EquationEditorSelectAllMenuItem"
                                      Header="Select All"
                                      Click="EquationEditorSelectAll_OnClick" />
                            <Separator />
                            <MenuItem Header="Submit"
                                      Click="EquationEditorSubmit_OnClick" />
                            <MenuItem Header="Cancel"
                                      Click="EquationEditorCancel_OnClick" />
                        </ContextMenu>
                    </TextBox.ContextMenu>
                </TextBox>
                <Grid Grid.Row="2"
                      IsVisible="{Binding IsFunctionDetailVisible}"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="8">
                    <DataGrid x:Name="FunctionTruthTableDataGrid"
                              Grid.Column="0"
                              ItemsSource="{Binding FunctionTruthTableRows}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserResizeColumns="True"
                              CanUserReorderColumns="False"
                              CanUserSortColumns="False"
                              GridLinesVisibility="All"
                              HeadersVisibility="Column"
                              Background="{DynamicResource LogicFriday.Brush.SurfaceContainerLowest}"
                              Foreground="{DynamicResource LogicFriday.Brush.OnSurface}"
                              BorderBrush="{DynamicResource LogicFriday.Brush.OutlineVariant}" />
                    <TextBox Grid.Column="1"
                             Text="{Binding LogicEquationText}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             FontFamily="Courier New"
                             TextWrapping="NoWrap"
                             Background="{DynamicResource LogicFriday.Brush.SurfaceContainerLowest}"
                             Foreground="{DynamicResource LogicFriday.Brush.OnSurface}"
                             BorderBrush="{DynamicResource LogicFriday.Brush.OutlineVariant}" />
                </Grid>
                <DataGrid x:Name="TruthTableDataGrid"
                          Grid.Row="2"
                          IsVisible="{Binding IsTruthTableVisible}"
                          ItemsSource="{Binding TruthTableRows}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserResizeColumns="True"
                          CanUserReorderColumns="False"
                          CanUserSortColumns="False"
                          SelectionMode="Extended"
                          GridLinesVisibility="All"
                          HeadersVisibility="Column"
                          Background="{DynamicResource LogicFriday.Brush.SurfaceContainerLowest}"
                          Foreground="{DynamicResource LogicFriday.Brush.OnSurface}"
                          BorderBrush="{DynamicResource LogicFriday.Brush.OutlineVariant}"
                          KeyDown="TruthTableDataGrid_OnKeyDown"
                          CellPointerPressed="TruthTableDataGrid_OnCellPointerPressed">
                    <DataGrid.ContextMenu>
                        <ContextMenu Opening="TruthTableContextMenu_OnOpening"
                                     Closing="TruthTableContextMenu_OnClosing">
                            <MenuItem Header="Select All"
                                      Click="TruthTableSelectAll_OnClick" />
                            <Separator />
                            <MenuItem x:Name="TruthTableSetTrueMenuItem"
                                      Header="True"
                                      Click="TruthTableSetTrue_OnClick" />
                            <MenuItem x:Name="TruthTableSetFalseMenuItem"
                                      Header="False"
                                      Click="TruthTableSetFalse_OnClick" />
                            <MenuItem x:Name="TruthTableSetDontCareMenuItem"
                                      Header="Don't Care"
                                      Click="TruthTableSetDontCare_OnClick" />
                            <MenuItem x:Name="TruthTableInvertMenuItem"
                                      Header="Invert"
                                      Click="TruthTableInvert_OnClick" />
                            <Separator />
                            <MenuItem Header="Submit"
                                      Click="TruthTableSubmit_OnClick" />
                            <MenuItem Header="Cancel"
                                      Click="TruthTableCancel_OnClick" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
                <Grid Grid.Row="2"
                      IsVisible="{Binding IsGateDiagramVisible}"
                      ColumnDefinitions="*,280"
                      ClipToBounds="True">
                    <controls:GateDiagramSurface Grid.Column="0"
                                                 SelectedPaletteItem="{Binding SelectedGatePaletteItem}" />
                    <Border Grid.Column="1"
                            BorderThickness="1,0,0,0"
                            BorderBrush="{DynamicResource LogicFriday.Brush.OutlineVariant}"
                            Background="{DynamicResource LogicFriday.Brush.SurfaceContainerLow}"
                            Padding="8"
                            ClipToBounds="True">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <Grid ColumnDefinitions="80,80,80"
                                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                  RowSpacing="4"
                                  ColumnSpacing="4">
                                <Button Grid.Row="0"
                                        Grid.Column="0"
                                        Classes="gatePaletteButton"
                                        Content="{Binding GatePaletteItems[3]}"
                                        Tag="{Binding GatePaletteItems[3]}"
                                        Click="GatePaletteButton_OnClick" />
                                <Button Grid.Row="0"
                                        Grid.Column="1"
                                        Classes="gatePaletteButton"
                                        Content="{Binding GatePaletteItems[4]}"
                                        Tag="{Binding GatePaletteItems[4]}"
                                        Click="GatePaletteButton_OnClick" />
                                <Button Grid.Row="0"
                                        Grid.Column="2"
                                        Classes="gatePaletteButton"
                                        Content="{Binding GatePaletteItems[5]}"
                                        Tag="{Binding GatePaletteItems[5]}"
                                        Click="GatePaletteButton_OnClick" />
                                <Button Grid.Row="1"
                                        Grid.Column="0"
                                        Classes="gatePaletteButton"
                                        Content="{Binding GatePaletteItems[6]}"
                                        Tag="{Binding GatePaletteItems[6]}"
                                        Click="GatePaletteButton_OnClick" />
                                <Button Grid.Row="1"
                                        Grid.Column="1"
                                        Classes="gatePaletteButton"
                                        Content="{Binding GatePaletteItems[7]}"
                                        Tag="{Binding GatePaletteItems[7]}"
                                        Click="GatePaletteButton_OnClick" />
                                <Button Grid.Row="1"
                                        Grid.Column="2"
                                        Classes="gatePaletteButton"
                                        Content="{Binding GatePaletteItems[8]}"
                                        Tag="{Binding GatePaletteItems[8]}"
                                        Click="GatePaletteButton_OnClick" />
                                <Button Grid.Row="2"
                                        Grid.Column="0"
                                        Classes="gatePaletteButton"
                                        Content="{Binding GatePaletteItems[10]}"
                                        Tag="{Binding GatePaletteItems[10]}"
                                        Click="GatePaletteButton_OnClick" />
                                <Button Grid.Row="2"
                                        Grid.Column="1"
                                        Classes="gatePaletteButton"
                                        Content="{Binding GatePaletteItems[11]}"
                                        Tag="{Binding GatePaletteItems[11]}"
                                        Click="GatePaletteButton_OnClick" />
                                <Button Grid.Row="2"
                                        Grid.Column="2"
                                        Classes="gatePaletteButton"
                                        Content="{Binding GatePaletteItems[12]}"
                                        Tag="{Binding GatePaletteItems[12]}"
                                        Click="GatePaletteButton_OnClick" />
                                <Button Grid.Row="3"
                                        Grid.Column="0"
                                        Classes="gatePaletteButton"
                                        Content="{Binding GatePaletteItems[13]}"
                                        Tag="{Binding GatePaletteItems[13]}"
                                        Click="GatePaletteButton_OnClick" />
                                <Button Grid.Row="3"
                                        Grid.Column="1"
                                        Classes="gatePaletteButton"
                                        Content="{Binding GatePaletteItems[14]}"
                                        Tag="{Binding GatePaletteItems[14]}"
                                        Click="GatePaletteButton_OnClick" />
                                <Button Grid.Row="3"
                                        Grid.Column="2"
                                        Classes="gatePaletteButton"
                                        Content="{Binding GatePaletteItems[15]}"
                                        Tag="{Binding GatePaletteItems[15]}"
                                        Click="GatePaletteButton_OnClick" />
                                <Button Grid.Row="4"
                                        Grid.Column="0"
                                        Classes="gatePaletteButton"
                                        Content="{Binding GatePaletteItems[2]}"
                                        Tag="{Binding GatePaletteItems[2]}"
                                        Click="GatePaletteButton_OnClick" />
                                <Button Grid.Row="4"
                                        Grid.Column="1"
                                        Classes="gatePaletteButton"
                                        Content="{Binding GatePaletteItems[18]}"
                                        Tag="{Binding GatePaletteItems[18]}"
                                        Click="GatePaletteButton_OnClick" />
                                <Button Grid.Row="4"
                                        Grid.Column="2"
                                        Classes="gatePaletteButton"
                                        Content="{Binding GatePaletteItems[9]}"
                                        Tag="{Binding GatePaletteItems[9]}"
                                        Click="GatePaletteButton_OnClick" />
                                <Button Grid.Row="5"
                                        Grid.Column="0"
                                        Classes="gatePaletteButton"
                                        Content="{Binding GatePaletteItems[16]}"
                                        Tag="{Binding GatePaletteItems[16]}"
                                        Click="GatePaletteButton_OnClick" />
                                <Button Grid.Row="5"
                                        Grid.Column="1"
                                        Classes="gatePaletteButton"
                                        Content="{Binding GatePaletteItems[17]}"
                                        Tag="{Binding GatePaletteItems[17]}"
                                        Click="GatePaletteButton_OnClick" />
                                <Button Grid.Row="6"
                                        Grid.Column="0"
                                        Classes="gatePaletteButton"
                                        Content="{Binding GatePaletteItems[19]}"
                                        Tag="{Binding GatePaletteItems[19]}"
                                        Click="GatePaletteButton_OnClick" />
                                <Button Grid.Row="6"
                                        Grid.Column="1"
                                        Classes="gatePaletteButton"
                                        Content="{Binding GatePaletteItems[20]}"
                                        Tag="{Binding GatePaletteItems[20]}"
                                        Click="GatePaletteButton_OnClick" />
                                <Button Grid.Row="7"
                                        Grid.Column="0"
                                        Classes="gatePaletteButton"
                                        Content="{Binding GatePaletteItems[0]}"
                                        Tag="{Binding GatePaletteItems[0]}"
                                        Click="GatePaletteButton_OnClick" />
                                <Button Grid.Row="7"
                                        Grid.Column="1"
                                        Classes="gatePaletteButton"
                                        Content="{Binding GatePaletteItems[1]}"
                                        Tag="{Binding GatePaletteItems[1]}"
                                        Click="GatePaletteButton_OnClick" />
                                <Button Grid.Row="8"
                                        Grid.Column="0"
                                        Classes="gatePaletteButton"
                                        Tag="{Binding GatePaletteItems[21]}"
                                        Click="GatePaletteButton_OnClick">
                                    <icons:PackIcon Kind="Check" />
                                </Button>
                                <Button Grid.Row="8"
                                        Grid.Column="1"
                                        Classes="gatePaletteButton"
                                        Tag="{Binding GatePaletteItems[22]}"
                                        Click="GatePaletteButton_OnClick">
                                    <icons:PackIcon Kind="Close" />
                                </Button>
                                <Button Grid.Row="8"
                                        Grid.Column="2"
                                        Classes="gatePaletteButton"
                                        Tag="{Binding GatePaletteItems[23]}"
                                        Click="GatePaletteButton_OnClick">
                                    <icons:PackIcon Kind="HelpCircle" />
                                </Button>
                            </Grid>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </DockPanel>

</Window>
