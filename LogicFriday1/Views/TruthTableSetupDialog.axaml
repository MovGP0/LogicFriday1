<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:LogicFriday1.Views"
        x:Class="LogicFriday1.Views.TruthTableSetupDialog"
        x:DataType="views:TruthTableSetupDialog"
        Title="Truth Table Setup"
        Width="460"
        Height="420"
        MinWidth="460"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <Grid RowDefinitions="Auto,*,Auto"
          Margin="12"
          RowSpacing="10">
        <Grid ColumnDefinitions="Auto,117,24,Auto,117"
              ColumnSpacing="8">
            <TextBlock Text="Inputs"
                       VerticalAlignment="Center" />
            <NumericUpDown Grid.Column="1"
                           Minimum="2"
                           Maximum="16"
                           Increment="1"
                           Value="{Binding InputCount, Mode=TwoWay}"
                           ValueChanged="InputCount_OnValueChanged" />

            <TextBlock Grid.Column="3"
                       Text="Outputs"
                       VerticalAlignment="Center" />
            <NumericUpDown Grid.Column="4"
                           Minimum="1"
                           Maximum="16"
                           Increment="1"
                           Value="{Binding OutputCount, Mode=TwoWay}"
                           ValueChanged="OutputCount_OnValueChanged" />
        </Grid>

        <Grid Grid.Row="1"
              ColumnDefinitions="*,*"
              ColumnSpacing="12">
            <GroupBox Header="Inputs">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Inputs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="views:TruthTableVariableName">
                                <TextBox Text="{Binding Name, Mode=TwoWay}"
                                         MaxLength="8"
                                         Margin="4,3" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </GroupBox>

            <GroupBox Grid.Column="1"
                      Header="Outputs">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Outputs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="views:TruthTableVariableName">
                                <TextBox Text="{Binding Name, Mode=TwoWay}"
                                         MaxLength="8"
                                         Margin="4,3" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </GroupBox>
        </Grid>

        <Grid Grid.Row="2"
              ColumnDefinitions="Auto,*,Auto,Auto"
              ColumnSpacing="8">
            <Button Content="Help"
                    MinWidth="80"
                    Click="HelpButton_OnClick" />
            <Button Grid.Column="2"
                    Content="OK"
                    MinWidth="80"
                    IsDefault="True"
                    Click="OkButton_OnClick" />
            <Button Grid.Column="3"
                    Content="Cancel"
                    MinWidth="80"
                    IsCancel="True"
                    Click="CancelButton_OnClick" />
        </Grid>
    </Grid>
</Window>
